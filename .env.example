POSTGRES_DB=dashboarddevops
POSTGRES_USER=devops
POSTGRES_PASSWORD=changeme_in_production

REDIS_URL=redis://redis:6379

TZ=America/Sao_Paulo

ASPNETCORE_ENVIRONMENT=Production
DATA_PROTECTION_KEY_PATH=/app/keys

# Versão da API do Azure DevOps REST API (ex: 7.1, 7.2, 6.0)
AZUREDEVOPS__APIVERSION=7.1

# JWT (troque em produção)
# Gere com: openssl rand -base64 64
JWT__KEY=DashboardDevops-SecretKey-Min32Chars-ChangeInProduction!!
JWT__ISSUER=DashboardDevops
JWT__AUDIENCE=DashboardDevops

# E-mail e senha padrão do usuário admin (criado automaticamente na primeira execução)
AUTH__DEFAULTADMINEMAIL=admin@configuracao.com.br
AUTH__DEFAULTPASSWORD=admin123

# Chave de criptografia para dados sensíveis (PAT tokens das organizações)
# Gere com: openssl rand -base64 32
# Obrigatório em produção para proteger dados no banco
ENCRYPTION__KEY=
